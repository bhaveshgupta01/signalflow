# ── Gemini AI ──────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Boba Agents MCP ───────────────────────────────────
BOBA_API_KEY=your-boba-api-key
BOBA_AGENT_ID=your-boba-agent-id
BOBA_AGENT_SECRET=your-boba-agent-secret

# ── Google Cloud (for Vertex AI backend) ──────────────
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1
USE_VERTEX=true

# ── Database (optional — defaults to signalflow.db) ───
SIGNALFLOW_DB_PATH=signalflow.db
